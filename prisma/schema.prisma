generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ──────────────────────────────────────────────
// NextAuth required models
// ──────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts             Account[]
  sessions             Session[]
  config               UserConfig?
  connectorConfigs     UserConnectorConfig[]
  pushChannels         PushChannel[]
  jobHistory           JobHistory[]
  failedJobs           FailedJob[]
  channelRenewalErrors ChannelRenewalError[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ──────────────────────────────────────────────
// Application models
// ──────────────────────────────────────────────

model UserConfig {
  id                       String   @id @default(cuid())
  userId                   String   @unique
  encryptedOpenRouterKey   String?  @db.Text
  encryptedSlackWebhookUrl String?  @db.Text
  slackUserId              String?
  meetingSummariesEnabled  Boolean  @default(false)
  slackDmEnabled           Boolean  @default(false)
  customSystemPrompt       String?  @db.Text
  drivePageToken           String?
  // Dismissal flags for UI nudge cards
  dismissedConnectorNudge  Boolean  @default(false)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ──────────────────────────────────────────────
// Connector configuration (additive destination model)
// ──────────────────────────────────────────────

model UserConnectorConfig {
  id           String          @id @default(cuid())
  userId       String
  connectorId  String          // 'nexus_history' | 'slack' | 'attio' | 'clickup'
  enabled      Boolean         @default(true)
  configJson   Json?           // Destination-specific config (e.g. Attio record, ClickUp space)
  oauthTokens  String?         @db.Text // Encrypted JSON: access_token, refresh_token, expires_at
  status       ConnectorStatus @default(DISCONNECTED)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, connectorId])
  @@index([userId])
}

model DeliveryLog {
  id           String         @id @default(cuid())
  summaryId    String
  connectorId  String         // 'nexus_history' | 'slack' | 'attio' | 'clickup'
  status       DeliveryStatus @default(PENDING)
  errorMessage String?        @db.Text
  deliveredAt  DateTime?
  retryCount   Int            @default(0)
  createdAt    DateTime       @default(now())

  summary JobHistory @relation(fields: [summaryId], references: [id], onDelete: Cascade)

  @@index([summaryId])
  @@index([connectorId])
  @@index([status])
}

enum ConnectorStatus {
  CONNECTED
  DISCONNECTED
  EXPIRED
}

enum DeliveryStatus {
  PENDING
  DELIVERED
  FAILED
}

model PushChannel {
  id         String   @id @default(cuid())
  userId     String
  channelId  String   @unique
  resourceId String
  watchToken String
  expiration DateTime
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiration])
  @@index([userId])
}

model JobHistory {
  id                   String    @id @default(cuid())
  userId               String
  workflowType         String    @default("MEETING_SUMMARY")
  status               JobStatus @default(PENDING)
  sourceFileId         String
  sourceFileName       String?
  llmModel             String?
  resultPayload        Json?
  destinationDelivered String?
  errorMessage         String?   @db.Text
  createdAt            DateTime  @default(now())
  completedAt          DateTime?

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliveryLogs DeliveryLog[]

  @@index([userId])
  @@index([status])
  @@index([userId, status])
  @@index([createdAt])
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model FailedJob {
  id           String   @id @default(cuid())
  userId       String?
  jobType      String
  payload      Json
  errorMessage String   @db.Text
  attempts     Int      @default(0)
  createdAt    DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([createdAt])
}

model ChannelRenewalError {
  id           String   @id @default(cuid())
  userId       String
  channelId    String
  errorMessage String   @db.Text
  acknowledged Boolean  @default(false)
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([acknowledged])
}
