generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ──────────────────────────────────────────────
// NextAuth required models
// ──────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts             Account[]
  sessions             Session[]
  config               UserConfig?
  pushChannels         PushChannel[]
  failedJobs           FailedJob[]
  channelRenewalErrors ChannelRenewalError[]

  // Foundation models
  sourceConnections      SourceConnection[]
  destinationConnections DestinationConnection[]
  sourceEvents           SourceEvent[]
  sourceItems            SourceItem[]
  workflowRuns           WorkflowRun[]
  artifacts              Artifact[]

  // Omnichannel triage
  pendingNotifications PendingNotification[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ──────────────────────────────────────────────
// Application configuration
// ──────────────────────────────────────────────

model UserConfig {
  id                      String   @id @default(cuid())
  userId                  String   @unique
  encryptedOpenRouterKey  String?  @db.Text
  meetingSummariesEnabled Boolean  @default(false)
  customSystemPrompt      String?  @db.Text
  dismissedConnectorNudge Boolean  @default(false)
  quietModeEnabled        Boolean  @default(false)
  digestSchedule          Json?    // e.g. { "times": ["12:00", "16:00"], "timezone": "America/New_York" }
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ──────────────────────────────────────────────
// Foundation: Enums
// ──────────────────────────────────────────────

enum SourceProvider {
  GOOGLE_DRIVE
  FIREFLIES
  SLACK
  TEAMS
  DISCORD
  OTHER
}

enum DestinationProvider {
  NEXUS_HISTORY
  SLACK
  CLICKUP
  NOTION
  EMAIL
  OTHER
}

enum WorkflowType {
  MEETING_SUMMARY
  ARTIFACT_REDELIVERY
  SCHEDULED_DIGEST
  OTHER
}

enum ArtifactType {
  MEETING_SUMMARY
  DIGEST
  TASK_BRIEF
  OTHER
}

enum RunStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELED
}

enum ConnectionStatus {
  CONNECTED
  DISCONNECTED
  EXPIRED
  ERROR
}

enum EventStatus {
  RECEIVED
  NORMALIZED
  QUEUED
  PROCESSED
  FAILED
  IGNORED
}

enum DeliveryStatus {
  PENDING
  DELIVERED
  FAILED
  SKIPPED
}

// ──────────────────────────────────────────────
// Foundation: Source Layer
// ──────────────────────────────────────────────

model SourceConnection {
  id                String           @id @default(cuid())
  userId            String
  provider          SourceProvider
  status            ConnectionStatus @default(DISCONNECTED)
  configJson        Json?
  externalAccountId String?
  displayName       String?
  lastValidatedAt   DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceEvents SourceEvent[]
  sourceItems  SourceItem[]

  @@unique([userId, provider])
  @@index([userId])
}

model SourceEvent {
  id                 String         @id @default(cuid())
  userId             String
  sourceConnectionId String
  provider           SourceProvider
  eventType          String
  externalEventId    String?
  dedupeKey          String?
  rawPayload         Json?
  normalizedMetadata Json?
  status             EventStatus    @default(RECEIVED)
  receivedAt         DateTime       @default(now())
  processedAt        DateTime?
  errorMessage       String?        @db.Text

  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceConnection SourceConnection @relation(fields: [sourceConnectionId], references: [id], onDelete: Cascade)
  workflowRuns     WorkflowRun[]

  @@index([userId])
  @@index([sourceConnectionId])
  @@index([dedupeKey])
  @@index([status])
}

model SourceItem {
  id                 String         @id @default(cuid())
  userId             String
  sourceConnectionId String
  provider           SourceProvider
  itemType           String
  externalItemId     String?
  title              String?
  contentText        String?        @db.Text
  contentJson        Json?
  sourceUrl          String?
  occurredAt         DateTime?
  metadata           Json?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceConnection SourceConnection @relation(fields: [sourceConnectionId], references: [id], onDelete: Cascade)

  @@unique([sourceConnectionId, externalItemId])
  @@index([userId])
  @@index([sourceConnectionId])
}

// ──────────────────────────────────────────────
// Foundation: Destination Layer
// ──────────────────────────────────────────────

model DestinationConnection {
  id                   String              @id @default(cuid())
  userId               String
  provider             DestinationProvider
  status               ConnectionStatus    @default(DISCONNECTED)
  enabled              Boolean             @default(true)
  configJson           Json?
  oauthTokensEncrypted String?             @db.Text
  externalAccountId    String?
  displayName          String?
  lastValidatedAt      DateTime?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  artifactDeliveries ArtifactDelivery[]

  @@unique([userId, provider])
  @@index([userId])
}

// ──────────────────────────────────────────────
// Foundation: Workflow Layer
// ──────────────────────────────────────────────

model WorkflowRun {
  id            String       @id @default(cuid())
  userId        String
  workflowType  WorkflowType
  triggerType   String       @default("EVENT")
  status        RunStatus    @default(PENDING)
  inputRefJson  Json?
  sourceEventId String?
  startedAt     DateTime?
  completedAt   DateTime?
  attemptCount  Int          @default(1)
  modelUsed     String?
  errorMessage  String?      @db.Text
  metricsJson   Json?
  createdAt     DateTime     @default(now())

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceEvent SourceEvent? @relation(fields: [sourceEventId], references: [id])
  artifacts   Artifact[]

  @@index([userId])
  @@index([status])
  @@index([userId, status])
  @@index([createdAt])
}

// ──────────────────────────────────────────────
// Foundation: Artifact Layer
// ──────────────────────────────────────────────

model Artifact {
  id             String       @id @default(cuid())
  userId         String
  artifactType   ArtifactType
  workflowRunId  String
  title          String?
  summaryText    String?      @db.Text
  payloadJson    Json?
  sourceRefsJson Json?
  status         String       @default("ACTIVE")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  workflowRun WorkflowRun        @relation(fields: [workflowRunId], references: [id], onDelete: Cascade)
  deliveries  ArtifactDelivery[]

  @@index([userId])
  @@index([workflowRunId])
  @@index([artifactType])
  @@index([createdAt])
}

model ArtifactDelivery {
  id                      String              @id @default(cuid())
  artifactId              String
  destinationConnectionId String?
  provider                DestinationProvider
  status                  DeliveryStatus      @default(PENDING)
  externalId              String?
  externalUrl             String?
  retryCount              Int                 @default(0)
  errorMessage            String?             @db.Text
  deliveredAt             DateTime?
  createdAt               DateTime            @default(now())

  artifact              Artifact               @relation(fields: [artifactId], references: [id], onDelete: Cascade)
  destinationConnection DestinationConnection? @relation(fields: [destinationConnectionId], references: [id])

  @@index([artifactId])
  @@index([destinationConnectionId])
  @@index([status])
}

// ──────────────────────────────────────────────
// Omnichannel Triage: Pending Notifications
// ──────────────────────────────────────────────

model PendingNotification {
  id                String   @id @default(cuid())
  userId            String
  connectorId       String   // e.g. "slack", "teams"
  externalMessageId String   // Platform-specific message ID for deduplication
  authorName        String
  content           String   @db.Text
  metadata          Json?    // Platform-specific routing data (channel ID, permalink, etc.)
  createdAt         DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, connectorId, externalMessageId])
  @@index([userId])
  @@index([createdAt])
}

// ──────────────────────────────────────────────
// Google Drive implementation details
// ──────────────────────────────────────────────

model PushChannel {
  id         String   @id @default(cuid())
  userId     String
  channelId  String   @unique
  resourceId String
  watchToken String
  expiration DateTime
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiration])
  @@index([userId])
}

// ──────────────────────────────────────────────
// Operational models
// ──────────────────────────────────────────────

model FailedJob {
  id           String   @id @default(cuid())
  userId       String?
  jobType      String
  payload      Json
  errorMessage String   @db.Text
  attempts     Int      @default(0)
  createdAt    DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([createdAt])
}

model ChannelRenewalError {
  id           String   @id @default(cuid())
  userId       String
  channelId    String
  errorMessage String   @db.Text
  acknowledged Boolean  @default(false)
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([acknowledged])
}
